APP_ENV=local
APP_NAME=AI Job Search Agent
LOG_LEVEL=INFO

POSTGRES_USER=jobagent
POSTGRES_PASSWORD=jobagent
POSTGRES_DB=jobagent
DATABASE_URL=postgresql+asyncpg://jobagent:jobagent@postgres:5432/jobagent

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

RESUME_STORAGE_PATH=/app/storage/resumes
PROFILE_RESUME_PATH=/app/storage/rahul_mathur_resume.pdf
BROWSER_STORAGE_PATH=/app/storage/browser
SCREENSHOT_STORAGE_PATH=/app/storage/screenshots

TARGET_JOB_TITLES=Lead Software Engineer,Staff Software Engineer
TARGET_JOB_LOCATIONS=Bengaluru,Remote
TARGET_JOB_REMOTE_ONLY=false
TARGET_YEARS_EXPERIENCE=10
TARGET_KEYWORDS=Java,Spring Boot,microservices,Kubernetes,cloud
LEVER_BOARDS=
GREENHOUSE_BOARDS=
ASHBY_BOARDS=

VITE_API_BASE_URL=http://localhost:8000/api/v1
